{
  "name": "eai-agentic-ide",
  "displayName": "eAI Agentic IDE Pro",
  "description": "Enterprise-grade agentic development environment. Local-first, workspace-aware, and evolutionary.",
  "version": "4.0.0",
  "publisher": "mlpaython",
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./out/extension.js",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package --out eai-pro-4.0.0.vsix"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.21.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "configuration": {
      "title": "eAI Pro",
      "properties": {
        "eai.backendUrl": {
          "type": "string",
          "default": "http://localhost:8000",
          "description": "FastAPI backend endpoint."
        },
        "eai.autoIndex": {
          "type": "boolean",
          "default": true,
          "description": "Automatically index workspace on startup."
        },
        "eai.terminalIntegration": {
          "type": "boolean",
          "default": true,
          "description": "Enable streaming terminal output to sidebar."
        }
      }
    },
    "commands": [
      {
        "command": "eai.focusSidebar",
        "title": "eAI: Focus Pro Sidebar",
        "category": "eAI"
      },
      {
        "command": "eai.applyAllDiffs",
        "title": "eAI: Apply All Pending Changes",
        "category": "eAI",
        "icon": "$(check-all)"
      },
      {
        "command": "eai.rejectAllDiffs",
        "title": "eAI: Reject All Pending Changes",
        "category": "eAI",
        "icon": "$(discard)"
      },
      {
        "command": "eai.undoLastChange",
        "title": "eAI: Undo Last Agent Change",
        "category": "eAI"
      },
      {
        "command": "eai.toggleTerminal",
        "title": "eAI: Toggle Sidebar Terminal",
        "category": "eAI"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "eaiProSidebar",
          "title": "eAI Pro",
          "icon": "media/robot.svg"
        }
      ]
    },
    "views": {
      "eaiProSidebar": [
        {
          "id": "eaiMainView",
          "name": "Orchestrator",
          "type": "webview"
        }
      ]
    },
    "keybindings": [
      {
        "command": "eai.focusSidebar",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      },
      {
        "command": "eai.applyAllDiffs",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "eai.toggleTerminal",
        "key": "ctrl+shift+m",
        "mac": "cmd+shift+m"
      }
    ]
  }
}
